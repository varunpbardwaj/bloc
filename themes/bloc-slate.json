		{
			"scope": [
				"entity.name.function.member",
				"meta.method-call entity.name.function",
				"meta.method entity.name.function"
			],
			"settings": {
				"foreground": "#88C0D0",
				"fontStyle": "underline"
			},
			"name": "Method"
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.struct",
				"entity.name.enum",
				"entity.name.union",
				"entity.name.namespace",
				"entity.name.scope-resolution",
				"support.class",
				"support.type",
				"support.type.object"
			],
			"settings": {
				"foreground": "#B48EAD",
				"fontStyle": "bold"
			},
			"name": "Class"
		},
		{
			"scope": [
				"entity.name.type.interface",
				"entity.name.type.alias",
				"entity.name.type.enum",
				"entity.name.type.parameter"
			],
			"settings": {
				"foreground": "#B48EAD",
				"fontStyle": "italic"
			},
			"name": "Interface"
		},
		{
			"scope": [
				"entity.other.inherited-class"
			],
			"settings": {
				"foreground": "#B48EAD",
				"fontStyle": "italic underline"
			},
			"name": "Inherited"
		},
		{
			"scope": [
				"storage.type.generic",
				"support.type.property-name",
				"support.type.builtin",
				"support.type.primitive"
			],
			"settings": {
				"foreground": "#B48EAD",
				"fontStyle": "italic"
			},
			"name": "Type"
		},
		{
			"scope": [
				"variable.other.property",
				"support.variable.property",
				"meta.object-literal.key",
				"meta.object-literal.key string",
				"meta.object-literal.key entity.name.tag",
				"string.unquoted.plain.out.yaml",
				"entity.name.tag.yaml"
			],
			"settings": {
				"foreground": "#94BFD4"
			},
			"name": "Property"
		},
		{
			"scope": [
				"entity.name.tag",
				"entity.name.tag.localname",
				"meta.tag",
				"meta.tag.sgml"
			],
			"settings": {
				"foreground": "#81A1C1"
			},
			"name": "Tag"
		},
		{
			"scope": [
				"support.class.component",
				"support.class.component.tsx",
				"support.class.component.jsx"
			],
			"settings": {
				"foreground": "#B48EAD",
				"fontStyle": "bold"
			},
			"name": "TSX Component"
		},
		{
			"scope": [
				"entity.name.tag.jsx",
				"entity.name.tag.tsx"
			],
			"settings": {
				"foreground": "#81A1C1"
			},
			"name": "JSX Tag"
		},
		{
			"scope": [
				"entity.other.attribute-name.jsx",
				"entity.other.attribute-name.tsx",
				"entity.other.attribute-name.class.jsx",
				"entity.other.attribute-name.class.tsx"
			],
			"settings": {
				"foreground": "#8BB1CB"
			},
			"name": "JSX Attribute"
		},
		{
			"scope": [
				"punctuation.section.embedded.begin.jsx",
				"punctuation.section.embedded.end.jsx",
				"punctuation.section.embedded.begin.tsx",
				"punctuation.section.embedded.end.tsx"
			],
			"settings": {
				"foreground": "#95C4D6"
			},
			"name": "JSX Delimiter"
		},
		{
			"scope": [
				"meta.import string.quoted",
				"string.quoted.double.import",
				"string.quoted.single.import"
			],
			"settings": {
				"foreground": "#A3BE8C"
			},
			"name": "Import Path"
		},
		{
			"scope": [
