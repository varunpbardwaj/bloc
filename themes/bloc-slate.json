				"support.variable.react"
			],
			"settings": {
				"foreground": "#88C0D0",
				"fontStyle": "underline"
			},
			"name": "React Hook"
		},
		{
			"scope": [
				"entity.other.attribute-name",
				"entity.other.attribute-name.class",
				"entity.other.attribute-name.id",
				"entity.other.attribute-name.pseudo-class",
